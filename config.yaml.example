# Net Sentry Configuration
# Copy this to config.yaml and customize as needed.

scan:
  # Run continuously in a loop
  continuous: false
  # Seconds between scan cycles (when continuous=true)
  interval_seconds: 60
  # Seconds of absence before starting a new visibility window
  gap_seconds: 300
  # Enable/disable individual scan types
  wifi_enabled: true        # Windows: netsh, Linux: nmcli/iw
  bluetooth_enabled: true   # Classic Bluetooth (Windows PowerShell backend)
  ble_enabled: true         # BLE scanning on Linux via bleak/BlueZ
  arp_enabled: true
  mdns_enabled: true
  ssdp_enabled: true
  netbios_enabled: true
  snmp_enabled: false
  monitor_mode_enabled: false

arp:
  resolve_hostnames: true
  max_concurrent: 10
  timeout_seconds: 2.0
  min_delay_seconds: 0.05
  max_delay_seconds: 0.2
  jitter: true

# Ping sweep for discovering hosts on remote subnets (useful in WSL2/NAT)
ping_sweep:
  enabled: false
  subnets: []
    # - "192.168.0.0/24"
  max_workers: 40
  timeout_seconds: 1.0
  # Map a CIDR subnet to a human-readable label for display/grouping.
  # If a host's source subnet matches, this label is shown in the "Segment" column.
  subnet_labels: {}
  # subnet_labels:
  #   "192.168.1.0/24": "office"
  #   "192.168.2.0/24": "IoT"
  #   "10.10.0.0/16": "servers"

snmp:
  community: "public"
  version: 2
  port: 161
  timeout_seconds: 2.0
  target_hosts: []
  # target_hosts:
  #   - "192.168.50.1"
  # Subnet to scan for SNMP-speaking devices (used by the SNMP plugin):
  subnet: ""   # e.g. "192.168.1.0/24"
  enabled: false
  max_hosts: 254

database:
  url: "sqlite:///net-sentry.db"
  # Number of days to keep visibility windows.  Set to 0 to keep forever (default).
  retention_days: 0
  # Run VACUUM on SQLite after a purge to reclaim disk space.
  vacuum_on_cleanup: true

alert:
  enabled: true
  log_new_devices: true
  log_file: null
  sound_enabled: false

# Add known/trusted devices here
whitelist: []
  # - mac_address: "AA:BB:CC:DD:EE:FF"
  #   name: "My Phone"
  #   category: "mobile"
  #   trusted: true

oui:
  auto_update: true
  update_interval_hours: 168  # 1 week
  cache_file: "src/data/oui_cache.txt"

monitor_mode:
  interface: "wlan0mon"
  use_docker: true
  docker_image: "btwifi-monitor:latest"
  channel_hop: true
  hop_interval_seconds: 0.5
  capture_duration_seconds: 30

# REST API / web dashboard settings
api:
  enabled: true
  host: "0.0.0.0"
  port: 8000
  # Enable JWT authentication for the /api/v1/* endpoints.
  # When disabled (default), the API is public.
  auth_enabled: false
  # Secret key used to sign JWT tokens.
  # Override via environment variable: BTWIFI_JWT_SECRET=<value>
  # IMPORTANT: generate a strong random secret for production!
  jwt_secret: "change-me-in-production-use-env-var"
  jwt_algorithm: "HS256"
  jwt_expire_minutes: 60
  # API users (username: bcrypt-hashed password).
  # Generate a hash with:  python -c "import bcrypt; print(bcrypt.hashpw(b'mypassword', bcrypt.gensalt()).decode())"
  api_users: {}
  #  admin: "$2b$12$examplehash..."
  # CORS allowed origins.  Override via: BTWIFI_CORS_ORIGINS=http://myapp.example.com
  cors_origins:
    - "http://localhost"
    - "http://127.0.0.1"

# ---------------------------------------------------------------------------
# TCP Port scanning
# Cached results are stored per-device in the database.
# Use --rescan-ports on the CLI to force a fresh scan.
# ---------------------------------------------------------------------------
port_scan:
  enabled: false
  # Ports to check on each discovered network device.
  ports: [21, 22, 23, 25, 53, 80, 443, 445, 3389, 8080, 8443]
  # Per-port connect timeout (seconds). Keep low to avoid slowing down scans.
  timeout_seconds: 0.5
  # Max concurrent port probes per host.
  max_workers: 20

# ---------------------------------------------------------------------------
# Home Assistant integration
# When enabled, Net Sentry queries the HA REST API once per scan cycle
# and uses the device_tracker.* entities to enrich device names and areas.
# ---------------------------------------------------------------------------
home_assistant:
  enabled: false
  # Base URL of your Home Assistant instance.
  url: ""  # e.g. "http://homeassistant.local:8123"
  # Long-lived access token (generate in HA Profile → Security).
  token: ""
  # HTTP timeout for the HA API call (seconds).
  timeout_seconds: 5.0

